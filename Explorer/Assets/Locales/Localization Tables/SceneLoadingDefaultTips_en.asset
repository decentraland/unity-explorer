  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: SceneLoadingDefaultTips_en
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: d8a2184e2c38d488f929003b0f0505af, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 191273726208528384
    m_Localized: "The Creator Hub gives you tools to build your own spaces, from
      simple hangouts to bigger experiences. What you build can become someone\u2019s
      regular spot."
    m_Metadata:
      m_Items: []
  - m_Id: 1078626870091776
    m_Localized: Show Up
    m_Metadata:
      m_Items: []
  - m_Id: 1078683115708416
    m_Localized: Spend time in Decentraland and earn Credits. Use them in the Marketplace
      to pick up Wearables and Emotes, no purchase needed. Shape your look as you
      go.
    m_Metadata:
      m_Items: []
  - m_Id: 1078715894194176
    m_Localized: Take a Shot
    m_Metadata:
      m_Items: []
  - m_Id: 1078768453017600
    m_Localized: "See something worth remembering? Press \u2018C\u2019 to open the
      Camera and \u2018Space bar\u2019 to snap a photo."
    m_Metadata:
      m_Items: []
  - m_Id: 191273272888152064
    m_Localized: Build Something
    m_Metadata:
      m_Items: []
  - m_Id: 191273924741713920
    m_Localized: Your Presence
    m_Metadata:
      m_Items: []
  - m_Id: 191273927132467200
    m_Localized: 'Badges reflect how you''ve spent time here: socializing, creating,
      or just being around. They show up on your profile so others get a sense of
      who they''re meeting.'
    m_Metadata:
      m_Items: []
  - m_Id: 197019265204740096
    m_Localized: Say Hi!
    m_Metadata:
      m_Items: []
  - m_Id: 197019292912312320
    m_Localized: "Emotes let you wave, react, or show off your moves without saying
      a word. Press \u2018B\u2019 to open the Emote Wheel and join the moment."
    m_Metadata:
      m_Items: []
  - m_Id: 197098386597339136
    m_Localized: Your Look
    m_Metadata:
      m_Items: []
  - m_Id: 197098550963724288
    m_Localized: "Wearables shape how you appear over time. Made by the community,
      they become part of how people recognize you\u2014and how you show off your
      style."
    m_Metadata:
      m_Items: []
  - m_Id: 197098607523913728
    m_Localized: Your People
    m_Metadata:
      m_Items: []
  - m_Id: 197098653933887488
    m_Localized: "Communities are how you find your people \u2014 from dance parties
      and chess matches to language practice, late-night talks, and art tours. Show
      up a few times and you start recognizing who\u2019s there."
    m_Metadata:
      m_Items: []
  - m_Id: 197098893369925632
    m_Localized: What's On
    m_Metadata:
      m_Items: []
  - m_Id: 197098927905824768
    m_Localized: Movie nights, trivia, dance parties, there's usually something happening.
      Drop in enough times and you'll start to recognize the regulars.
    m_Metadata:
      m_Items: []
  - m_Id: 197099039080046592
    m_Localized: Your Space
    m_Metadata:
      m_Items: []
  - m_Id: 197099055790153728
    m_Localized: 'Your World is yours to do what you want with: build, experiment,
      hang out, host. You can also wander into other people''s Worlds and see what
      they''ve put together.'
    m_Metadata:
      m_Items: []
  - m_Id: 197397929998147584
    m_Localized: Hang Out
    m_Metadata:
      m_Items: []
  - m_Id: 197397960180359168
    m_Localized: "Genesis Plaza is the place people tend to hang\u2014around the
      fire pit, in conversation, crossing paths, feeding pigeons. Come by and see
      who\u2019s around!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
