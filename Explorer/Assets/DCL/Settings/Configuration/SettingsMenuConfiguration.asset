          m_SubObjectName: 
          m_SubObjectType: 
          m_SubObjectGUID: 
          m_EditorAssetChanged: 0
        <Config>k__BackingField:
          <ModuleName>k__BackingField: HDR
          <Description>k__BackingField: Enhances the range of colours and brightness
            in the scene, making lights brighter and shadows deeper. Produces a more
            visually realistic image. Disable this on lower-end devices to improve
            performance.
          <IsEnabled>k__BackingField: 1
          defaultIsOn: 0
        <Feature>k__BackingField: 4
    - rid: 2404945502817747083
      type: {class: ToggleModuleBinding, ns: DCL.Settings.Configuration, asm: Settings}
