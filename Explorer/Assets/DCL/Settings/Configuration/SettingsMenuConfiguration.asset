          m_SubObjectName: 
          m_SubObjectType: 
          m_SubObjectGUID: 
          m_EditorAssetChanged: 0
        <Config>k__BackingField:
          <ModuleName>k__BackingField: Bloom
          <Description>k__BackingField: Adds a soft glow effect around bright light
            sources, mimicking how real eyes perceive intense light. This is a purely
            visual effect turning it off has no impact on gameplay but can improve
            performance on weaker devices.
          <IsEnabled>k__BackingField: 1
          defaultIsOn: 0
        <Feature>k__BackingField: 5
    - rid: 2404945502817747084
