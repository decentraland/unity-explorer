          m_SubObjectName: 
          m_SubObjectType: 
          m_SubObjectGUID: 
          m_EditorAssetChanged: 0
        <Config>k__BackingField:
          <ModuleName>k__BackingField: MSAA
          <Description>k__BackingField: Smooths out jagged edges on objects and surfaces.
