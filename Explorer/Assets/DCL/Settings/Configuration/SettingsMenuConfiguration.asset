        <Config>k__BackingField:
          <ModuleName>k__BackingField: FPS Limit
          <Description>k__BackingField: Caps the maximum number of frames rendered
            per second. Lower values reduce GPU and CPU load, helping keep your device
            cool and quiet. Higher values deliver smoother motion if your hardware
            can keep up.
          <IsEnabled>k__BackingField: 1
          isMultiselect: 0
          options:
          - Max
          - 30
          - 60
          - 120
          - 144
          defaultOptionIndex: 1
        <Feature>k__BackingField: 5
    - rid: 2404945502817747041
      type: {class: SliderModuleBinding, ns: DCL.Settings.Configuration, asm: Settings}
      data:
        <FeatureId>k__BackingField: 0
        <View>k__BackingField:
          m_AssetGUID: 27c8bedb89b5739458399a3bd3d255ac
          m_SubObjectName: 
          m_SubObjectType: 
          m_SubObjectGUID: 
          m_EditorAssetChanged: 0
        <Config>k__BackingField:
          <ModuleName>k__BackingField: Resolution Scale
          <Description>k__BackingField: Renders the scene at a lower or higher percentage
            of your display resolution, then scales the image to fit. Lowering this
            value significantly improves performance at the cost of sharpness.
          <IsEnabled>k__BackingField: 1
          sliderType: 3
          minValue: 5
          maxValue: 12
          wholeNumbers: 1
          defaultValue: 10
        <Feature>k__BackingField: 10
    - rid: 2404945502817747070
      type: {class: DropdownModuleBinding, ns: DCL.Settings.Configuration, asm: Settings}
      data:
        <FeatureId>k__BackingField: 0
